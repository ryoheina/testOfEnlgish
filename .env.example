# Database (Railway PostgreSQL — auto-set when you add a Postgres plugin)
DATABASE_URL="postgresql://postgres:password@localhost:5432/english_test?schema=public"

# JWT Secret (generate a strong random string for production)
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-32-chars"

# Admin default credentials (used only during seed)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="your-secure-password"

# Set to "true" on first Railway deploy to create admin + sample questions
RUN_SEED="false"

# Optional: persistent upload directory (mount a Railway volume here)
# UPLOAD_DIR="/app/data/uploads"

# App Configuration
NEXT_PUBLIC_APP_NAME="English Test Platform"
NEXT_PUBLIC_PASS_PERCENTAGE=60
NEXT_PUBLIC_DEFAULT_QUESTION_COUNT=20
NEXT_PUBLIC_ENABLE_TIMER=true
NEXT_PUBLIC_TIMER_MINUTES=30

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000

# CSRF
CSRF_SECRET="your-csrf-secret-change-in-production"

# File Upload
MAX_FILE_SIZE_MB=10
