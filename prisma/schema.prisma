generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String   @map("password_hash")
  name         String
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("admins")
}

model Student {
  id         String       @id @default(uuid())
  fullName   String       @map("full_name")
  studentId  String?      @map("student_id")
  createdAt  DateTime     @default(now()) @map("created_at")
  results    TestResult[]

  @@map("students")
}

model TestResult {
  id          String   @id @default(uuid())
  studentId   String   @map("student_id")
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  score       Int
  total       Int
  percentage  Float
  passed      Boolean
  timeTaken   Int?     @map("time_taken")
  ipAddress   String?  @map("ip_address")
  answers     Json
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([percentage])
  @@map("test_results")
}

model Question {
  id            String   @id @default(uuid())
  questionText  String   @map("question_text")
  optionA       String   @map("option_a")
  optionB       String   @map("option_b")
  optionC       String   @map("option_c")
  optionD       String   @map("option_d")
  correctAnswer String   @map("correct_answer")
  category      String?
  difficulty    String   @default("medium")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([isActive])
  @@map("questions")
}

model DownloadableFile {
  id          String   @id @default(uuid())
  fileName    String   @map("file_name")
  filePath    String   @map("file_path")
  mimeType    String   @map("mime_type")
  fileSize    Int      @map("file_size")
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("downloadable_files")
}

model TestConfig {
  id                    String   @id @default(uuid())
  questionCount         Int      @default(20) @map("question_count")
  passPercentage        Int      @default(60) @map("pass_percentage")
  timerEnabled          Boolean  @default(true) @map("timer_enabled")
  timerMinutes          Int      @default(30) @map("timer_minutes")
  randomizeQuestions    Boolean  @default(true) @map("randomize_questions")
  randomizeAnswers      Boolean  @default(true) @map("randomize_answers")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("test_config")
}

model TestProgress {
  id           String   @id @default(uuid())
  sessionId    String   @unique @map("session_id")
  csrfToken    String   @map("csrf_token")
  studentData  Json     @map("student_data")
  answers      Json     @map("answers")
  currentIndex Int      @default(0) @map("current_index")
  questionIds  Json     @map("question_ids")
  startedAt    DateTime @default(now()) @map("started_at")
  expiresAt    DateTime @map("expires_at")

  @@index([expiresAt])
  @@map("test_progress")
}
